@startuml activity_cfg

skinparam classAttributeIconSize 0
hide empty members

class ActivityCfg {
  +entry: NodeId
  +exit: NodeId
  +nodes: Vec<CfgNode>
  +edges: Vec<CfgEdge>
}

abstract class CfgNode {
  +id: NodeId
}

class EntryNode
class ExitNode

class StepNode {
  +label: String
  +kind: StepKind
}

class DecisionNode {
  +condition: String
}

class MergeNode

class CfgEdge {
  +from: NodeId
  +to: NodeId
  +kind: EdgeKind
}

enum StepKind {
  Action
  Backward
  Control
}

enum EdgeKind {
  Next
  True
  False
  Back
  Break
  Continue
  Abort
}

ActivityCfg *-- "1..*" CfgNode : nodes
ActivityCfg *-- "0..*" CfgEdge : edges

CfgNode <|-- EntryNode
CfgNode <|-- ExitNode
CfgNode <|-- StepNode
CfgNode <|-- DecisionNode
CfgNode <|-- MergeNode

@enduml
