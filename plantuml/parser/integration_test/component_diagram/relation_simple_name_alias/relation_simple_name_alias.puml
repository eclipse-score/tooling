@startuml "Relation with Simple Name Alias"

package "Pkg A" as PkgA {
    component "Component A" as AliasA <<component>> {
    }
}

package "Pkg B" as PkgB {
    component "Component B" as AliasB <<component>> {
    }
}

PkgA.AliasA --> AliasB : uses

@enduml
