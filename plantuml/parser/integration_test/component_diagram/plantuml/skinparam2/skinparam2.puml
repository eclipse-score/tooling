@startuml

skinparam component {
  backgroundColor<<sealed module>> PaleGreen
  backgroundColor<<runtime module>> LightSkyBlue
}

skinparam node {
  borderColor SteelBlue
  backgroundColor WhiteSmoke
  backgroundColor<<diagnostic_host>> Plum
}
skinparam databaseBackgroundColor Lavender

[RecorderCore] <<sealed module>>
[StreamBridge] <<runtime module>>
[ReplayHarness] <<sealed module>>

node fieldRig
node labRig <<diagnostic_host>>
database FleetCache

@enduml
