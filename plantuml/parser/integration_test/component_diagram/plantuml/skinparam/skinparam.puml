@startuml

skinparam interface {
  backgroundColor HoneyDew
  borderColor DarkSlateGray
}

skinparam component {
  FontSize 12
  BackgroundColor<<Critical>> LightCoral
  BorderColor<<Critical>> #335577
  FontName Monospace
  BorderColor DimGray
  BackgroundColor MintCream
  ArrowFontName SansSerif
  ArrowColor #335577
  ArrowFontColor #224466
}

() "Command Intake" as CmdIn
Component "Analysis Worker" as Analyzer << Critical >>

CmdIn - [Telemetry Gateway]
[Telemetry Gateway] ..> () TraceBus : publishes
TraceBus - Analyzer

@enduml
