@startuml

package "Pkg" as Pkg {
    component "Client" as Client <<component>> {
        portout pOut
        portin pIn
        port pAny
    }

    interface "IProvided" as IProvided
    interface "IRequired" as IRequired

    pOut )- IProvided : provides
    pIn -( IRequired : requires
}

@enduml
