@startuml if

if (beta syntax enabled?) then
  :Enter beta flow;
  if (extra validation needed?) then (yes)
    :Run nested validation;
  else (no)
    :Skip nested validation;
    stop
  endif
else (no)
  :Fallback configuration path;
  kill
endif

stop

@enduml
