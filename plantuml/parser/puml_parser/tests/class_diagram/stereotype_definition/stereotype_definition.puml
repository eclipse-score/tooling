@startuml stereotype_definition

class User <<Model>> {
  - id: int
  + getName(): String
}

struct Config <<Singleton, Immutable>> {
  - instance: Config
}

interface AbstractService <<abstract>> {
  + doSomething(): void
}

enum Gender <<enum>> {
  MALE
  FEMALE
}

@enduml
