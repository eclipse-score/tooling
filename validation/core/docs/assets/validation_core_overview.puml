@startuml validation_core_overview
title Validation Core — Component Overview

skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultTextAlignment center
skinparam componentStyle rectangle

' ── External input artifacts ──────────────────────────────────────────────────

rectangle "Input Artifacts" as Inputs {
  file "architecture.json\n(Bazel build graph)" as FBazel
  file "*.component.fbs\n(PlantUML export)" as FComp
  file "*.sequence.fbs\n(PlantUML export)" as FSeq
  file "*.class.fbs\n(PlantUML export)" as FClass
}

' ── validation/core library ───────────────────────────────────────────────────

package "validation/core" {

  ' Readers: parse raw file formats into typed raw models
  package "Readers  [Reader trait]" as ReadLayer {
    component "BazelReader" as BR
    component "ComponentDiagramReader" as CDR
    component "SequenceDiagramReader" as SDR
    component "ClassDiagramReader" as ClDR
  }

  ' Models: indexed, query-ready in-memory representations
  package "Models" as ModelLayer {
    component "BazelArchitecture\n(SEooC / component / unit sets)" as MBazel
    component "ComponentDiagramArchitecture\n(entities by stereotype)" as MComp
    component "SequenceDiagramIndex\n(used participant set)" as MSeq
    component "ClassDiagramIndex\n(enclosing namespace set)" as MClass
  }

  ' Validators: stateless pure functions; auto-selected by available inputs
  package "Validators  [auto-selected by available inputs]" as ValLayer {
    component "validate_bazel_component\nBuild graph ↔ Architecture diagram" as VBC
    component "validate_component_class\nUnit IDs ↔ Namespace IDs" as VCC
    component "validate_component_sequence\nUnit aliases ↔ Sequence participants" as VCS
  }

  component "Errors" as Err

  component "CLI Orchestrator\n(main.rs)\n\n① Parse CLI args\n② Drive Readers → build ValidationContext\n③ Auto-select Validators\n④ Merge errors → write report" as CLI

}

' ── Output ────────────────────────────────────────────────────────────────────
file "Validation Report\n(JSON log + exit code)" as Report

' ── Connections ───────────────────────────────────────────────────────────────

' Inputs feed Readers
FBazel --> BR
FComp  --> CDR
FSeq   --> SDR
FClass --> ClDR

' Readers produce Models (parse + index)
BR  --> MBazel
CDR --> MComp
SDR --> MSeq
ClDR --> MClass

' Component diagram is the shared reference hub for all validators
MBazel --> VBC
MComp  --> VBC
MComp  --> VCC
MComp  --> VCS
MClass --> VCC
MSeq   --> VCS

' Validators accumulate into Errors
VBC --> Err
VCC --> Err
VCS --> Err

' CLI orchestrates Readers and Validators
CLI ..> ReadLayer : drives
CLI ..> ValLayer  : selects & runs

' Final output
Err --> Report : CLI writes

note right of ValLayer
  Each validator requires a specific pair of models.
  Validators not meeting their input requirements
  are silently skipped (no error).
end note

note right of MComp
  ComponentDiagramArchitecture is the
  shared reference across all three validators.
end note

@enduml
